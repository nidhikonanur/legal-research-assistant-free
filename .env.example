# Copy to .env and edit
PORT=3000
# Required for CourtListener search requests.
COURTLISTENER_API_KEY=
# LLM_PROVIDER: 'ollama' or 'dummy'
LLM_PROVIDER=dummy
# If using ollama, set the base URL (default ollama HTTP API)
OLLAMA_URL=http://localhost:11434
# Ollama model name used for local generation
OLLAMA_MODEL=llama2
# Number of passages to retrieve
TOP_K=4
